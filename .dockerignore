# =============================================================================
# Harvest Agent — Docker ignore
# =============================================================================
# Keep image context small and avoid leaking dev artifacts into containers.
# =============================================================================

# Version control
.git
.gitignore

# Python artifacts
__pycache__
*.pyc
*.pyo
*.egg-info
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# Test / dev files (not needed in production image)
tests/
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Hermes internals
.hermes/

# OS artifacts
.DS_Store
Thumbs.db

# Docker files (don't copy into image context)
Dockerfile
docker-compose.yml
docker-compose*.yml
.dockerignore

# Docs / misc
LICENSE
*.md
!README.md
docs/
